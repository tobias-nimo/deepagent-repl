# LangGraph server URL
# LANGGRAPH_URL=http://localhost:2024

# Graph ID (default: auto-discover from server)
# GRAPH_ID=...

# LangSmith API key (optional, for authenticated LangGraph Cloud connections)
# LANGSMITH_API_KEY=...

# REPL accent color (any Rich color name or hex code, default: cyan)
# DEEPAGENT_COLOR=#e86e48
